# Server-only — never use NEXT_PUBLIC_ for this key
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROJECT_WALLET=your_project_wallet_address
NEXT_PUBLIC_PRO_PRICE_SOL=0.05
NEXT_PUBLIC_EXTRA_PRICE_SOL=0.2

# Optional custom RPC (recommended for production)
# NEXT_PUBLIC_SOLANA_RPC_URL=
